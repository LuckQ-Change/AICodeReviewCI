{
  "repo": {
    "path": "${REPO_PATH}"
  },
  "model": {
    "provider": "openai",
    "options": {
      "baseURL": "${AI_BASE_URL}",
      "apiKey": "${AI_API_KEY}",
      "model": "hunyuan-pro"
    }
  },
  "notifications": {
    "lark": {
      "enabled": true,
      "secret": "${LARK_SECRET}",
      "appId": "${LARK_APP_ID}",
      "appSecret": "${LARK_APP_SECRET}",
      "chatId": "${LARK_CHAT_ID}"
    },
    "wecom": {
      "enabled": false,
      "webhook": ""
    },
    "email": {
      "enabled": false,
      "smtp": {
        "host": "",
        "port": 465,
        "secure": true,
        "user": "",
        "pass": ""
      },
      "from": "AI Code Review <noreply@example.com>"
    }
  },
  "mention_map": {
    "email_to_lark_open_id": {},
    "email_to_wecom_userid": {}
  },
  "schedule": {
    "intervalMinutes": 1,
    "dailyTime": "18:00",
    "cron": ""
  },
  "review": {
    "maxSnippetsPerCommit": 2,
    "maxLinesPerSnippet": 20
  }
}