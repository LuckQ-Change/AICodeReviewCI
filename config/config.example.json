{
  "repo": {
    "path": "${REPO_PATH}"
  },
  "model": {
    "provider": "openai",
    "options": {
      "apiKey": "${AI_API_KEY}",
      "baseURL": "${AI_BASE_URL}",
      "model": "gpt-4o-mini"
    }
  },
  "notifications": {
    "lark": {
      "enabled": false,
      "webhook": "${LARK_WEBHOOK}",
      "secret": "${LARK_SECRET}",
      "appId": "${LARK_APP_ID}",
      "appSecret": "${LARK_APP_SECRET}",
      "chatId": "${LARK_CHAT_ID}"
    },
    "wecom": {
      "enabled": false,
      "webhook": "https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxx"
    },
    "email": {
      "enabled": false,
      "smtp": {
        "host": "${EMAIL_SMTP_HOST}",
        "port": 465,
        "secure": true,
        "user": "${EMAIL_SMTP_USER}",
        "pass": "${EMAIL_SMTP_PASS}"
      },
      "from": "AI Code Review <${EMAIL_FROM}>"
    },
    "reportStyle": "issues_only",
    "snippetFormat": "no_headers",
    "skipWhenNoSnippets": true
  },
  "mention_map": {
    "email_to_lark_open_id": {
      "dev1@example.com": "ou_xxx"
    },
    "email_to_wecom_userid": {
      "dev1@example.com": "zhangsan"
    }
  },
  "schedule": {
    "intervalMinutes": 60,
    "dailyTime": "18:00",
    "cron": "" 
  },
  "review": {
    "maxSnippetsPerCommit": 2,
    "maxLinesPerSnippet": 20,
    "include": ["src/**/*.{js,ts}", "lib/**/*.js"],
    "exclude": ["src/vendor/**", "**/*.md"]
  },
  "rules": {
    "dir": "rules"
  }
}